# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bagsandbeyond
DB_USER=root
DB_PASSWORD=

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Payment Providers
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
MONNIFY_API_KEY=your_monnify_api_key_here
MONNIFY_SECRET_KEY=your_monnify_secret_key_here
MONNIFY_CONTRACT_CODE=your_monnify_contract_code_here
OPAY_SECRET_KEY=your_opay_secret_key_here

# Email configuration
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
SMTP_SENDER=sender@example.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
